{
  "audience": "8-year-old mobile English spelling learners",
  "phonics_rules": [
    { "id": "short-u-o", "title": "Short /u/ as 'o'", "zh": "o 讀短 /u/", "pattern": "o → /u/", "examples": ["mother", "monkey", "other", "above"] },
    { "id": "short-i-y", "title": "Short /i/ as 'y'", "zh": "y 讀短 /i/", "pattern": "y → /i/", "examples": ["gym", "mystery", "symbol", "system"] },
    { "id": "long-a-ey", "title": "Long /a/ as 'ey'", "zh": "ey 讀長 /a/", "pattern": "ey → /ā/", "examples": ["obey", "prey", "they", "grey"] },
    { "id": "long-a-ai", "title": "Long /a/ as 'ai'", "zh": "ai 讀長 /a/", "pattern": "ai → /ā/", "examples": ["rain", "plain", "train", "paint"] },
    { "id": "long-a-ei", "title": "Long /a/ as 'ei'", "zh": "ei 讀長 /a/", "pattern": "ei → /ā/", "examples": ["reign", "weight", "veil", "sleigh"] },
    { "id": "ur-ear", "title": "Sound /ur/ as 'ear'", "zh": "ear 讀 /ur/", "pattern": "ear → /ûr/", "examples": ["earth", "learn", "early", "search"] },
    { "id": "k-ch", "title": "Sound /k/ as 'ch'", "zh": "ch 發 /k/", "pattern": "ch → /k/", "examples": ["echo", "chaos", "stomach", "school"] },
    { "id": "gue-que", "title": "gue / que endings", "zh": "特殊字尾", "pattern": "gue / que", "examples": ["league", "antique", "unique", "plaque"] },
    { "id": "ary", "title": "-ary ending", "zh": "多音節字尾", "pattern": "-ary", "examples": ["dictionary", "library", "ordinary", "primary"] }
  ],
  "morphology": {
    "prefixes": [
      { "value": "un-", "meaning": "Not / 相反", "example": "unhappy" },
      { "value": "re-", "meaning": "Again / 再次", "example": "replay" },
      { "value": "dis-", "meaning": "Negative / 否定", "example": "disagree" },
      { "value": "mis-", "meaning": "Wrongly / 錯誤地", "example": "misread" },
      { "value": "pre-", "meaning": "Before / 之前", "example": "preview" },
      { "value": "in-", "meaning": "Not / 不", "example": "inactive" },
      { "value": "im-", "meaning": "Not / 不", "example": "impossible" },
      { "value": "non-", "meaning": "Not / 非", "example": "nonstop" },
      { "value": "over-", "meaning": "Too much / 過多", "example": "overcook" },
      { "value": "sub-", "meaning": "Under / 在...之下", "example": "submarine" }
    ],
    "suffixes": [
      { "value": "-ly", "meaning": "Basic change", "example": "quickly" },
      { "value": "-ly", "meaning": "y changes to ily", "example": "happily" },
      { "value": "-ly", "meaning": "le changes to ly", "example": "gently" },
      { "value": "-ally", "meaning": "ic/al changes to ally", "example": "magically" },
      { "value": "-ful", "meaning": "Full of / 充滿...", "example": "helpful" },
      { "value": "-less", "meaning": "Without / 沒有...", "example": "careless" },
      { "value": "-ness", "meaning": "State / 狀態", "example": "kindness" },
      { "value": "-ment", "meaning": "Action/process / 動作或過程", "example": "movement" },
      { "value": "-able", "meaning": "Can be / 可以被...", "example": "readable" }
    ]
  },
  "visual_phonics": {
    "red": "Short vowels",
    "skyblue": "Long vowels / vowel teams",
    "orange": "Digraphs / blends",
    "purple": "R-controlled sounds",
    "blue": "Silent letters",
    "green": "Variant / schwa sounds"
  },
  "special_categories": {
    "homophones": [["to", "two", "too"], ["rain", "reign"], ["plain", "plane"]],
    "tricky_words": ["one", "said", "could", "because", "friend"],
    "cool_words": ["pizza", "robot", "scooter", "dinosaur", "galaxy"]
  }
}
