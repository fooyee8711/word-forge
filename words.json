    {
      "word": "REFORM",
      "formula": ["P_RE", "R_FORM"],
      "definition": "To make changes in order to improve something.",
      "usage_example": "The school decided to reform its rules to be more fair.",
      "lexile_level": 650
    },
    {
      "word": "PORTABLE",
      "formula": ["R_PORT", "S_ABLE"],
      "definition": "Able to be easily carried or moved.",
      "usage_example": "We brought a portable stove on our camping trip.",
      "lexile_level": 700
    },
    {
      "word": "BIOLOGY",
      "formula": ["R_BIO", "S_OLOGY"],
      "definition": "The scientific study of life and living organisms.",
      "usage_example": "In biology class, we looked at plant cells under a microscope.",
      "lexile_level": 800
    },
    {
      "word": "UNPREDICTABLE",
      "formula": ["P_UN", "P_PRE", "R_DICT", "S_ABLE"],
      "definition": "Not able to be foreseen or known beforehand.",
      "usage_example": "The weather in the mountains can be highly unpredictable.",
      "lexile_level": 850
    },
    {
      "word": "TRANSFORMATION",
      "formula": ["P_TRANS", "R_FORM", "S_ATION"],
      "definition": "A complete change in shape, appearance, or nature.",
      "usage_example": "The caterpillar's transformation into a butterfly is magical.",
      "lexile_level": 880
    },
    {
      "word": "CONTRADICT",
      "formula": ["P_CONTRA", "R_DICT"],
      "definition": "To state the opposite of what someone else has said.",
      "usage_example": "The witness's new story seemed to contradict the evidence.",
      "lexile_level": 920
    },
    {
      "word": "SYNCHRONIZE",
      "formula": ["P_SYN", "R_CHRON", "S_IZE"],
      "definition": "To cause things to happen at exactly the same time.",
      "usage_example": "The dancers had to perfectly synchronize their movements.",
      "lexile_level": 950
    },
    {
      "word": "DEMOCRACY",
      "formula": ["R_DEM", "S_CRACY"],
      "definition": "A system of government where power is held by the people.",
      "usage_example": "Voting in elections is a core part of a democracy.",
      "lexile_level": 980
    },
    {
      "word": "PHILOSOPHY",
      "formula": ["R_PHIL", "R_SOPH", "S_Y"],
      "definition": "The study of the fundamental nature of knowledge, reality, and existence.",
      "usage_example": "Ancient Greek philosophy still influences how we think today.",
      "lexile_level": 1050
    },
    {
